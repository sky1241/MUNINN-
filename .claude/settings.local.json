{
  "hooks": {
    "PreCompact": [
      {
        "type": "command",
        "command": "python engine/core/muninn.py feed --repo ."
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "python engine/core/muninn.py feed --repo ."
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python engine/core/muninn.py feed --repo . --trigger stop"
      }
    ]
  }
}
